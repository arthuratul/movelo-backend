enum ClientType {
  PUBLIC
  CONFIDENTIAL
}

model OAuthClient {
  id                 String              @id @default(uuid())
  clientSecret       String?
  clientType         ClientType          @default(PUBLIC)
  name               String
  redirectUris       String[]
  createdAt          DateTime            @default(now())
  authorizationCodes AuthorizationCode[]
  refreshTokens      RefreshToken[]

  @@map("oauth_clients")
}